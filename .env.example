# ── LLM Provider ──────────────────────────────────────────────────────────────
# "bedrock" (AWS) or "openai"
LLM_PROVIDER=bedrock

# ── AWS Bedrock credentials ────────────────────────────────────────────────────
# Required if LLM_PROVIDER=bedrock.
# If running on EC2/Lambda with an IAM role, leave these blank — boto3 auto-detects.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Required for embeddings (always used, regardless of LLM_PROVIDER).
# Also used for LLM calls if LLM_PROVIDER=openai.
OPENAI_API_KEY=sk-your_openai_api_key

# ── Embedding gateway (optional) ──────────────────────────────────────────────
# If you're routing embeddings through a custom gateway (e.g. CMU AI Gateway),
# set this. Otherwise leave blank to use api.openai.com directly.
EMBEDDING_BASE_URL=https://api.openai.com
