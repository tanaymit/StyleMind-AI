    "Casual Shoes": (35, 100), "Sports Shoes": (40, 120),
    "Formal Shoes": (50, 150), "Watches": (30, 200), "Kurtas": (20, 70),
    "Tops": (15, 55), "Handbags": (25, 150), "Heels": (30, 120),
    "Sunglasses": (15, 80), "Wallets": (15, 60), "Belts": (15, 50),
    "Sandals": (15, 60), "Flip Flops": (10, 35), "Dresses": (30, 120),
    "Trousers": (25, 80), "Shorts": (15, 50), "Jackets": (40, 150),
